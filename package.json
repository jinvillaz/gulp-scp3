{
  "name": "gulp-scp3",
  "version": "1.0.1",
  "description": "Modern TypeScript Gulp plugin for SCP via SSH2 (Node 20+, Gulp 4/5)",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "mocha --require ts-node/register test/client.test.ts --timeout 5000",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "gulp",
    "scp",
    "ssh2",
    "sftp",
    "typescript",
    "deployment"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "gulp": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.7.4",
    "@types/ssh2": "^1.15.5",
    "cross-env": "^10.1.0",
    "gulp": "^5.0.0",
    "mocha": "^11.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "author": {
    "name": "Jhonatan Villanueva",
    "email": "jinvillaz@gmail.com",
    "url": "https://github.com/jinvillaz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jinvillaz/gulp-scp3.git"
  },
  "license": "MIT",
  "files": [
    "lib/**/*",
    "README.md"
  ]
}
